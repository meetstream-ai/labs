# ──────────────────────────────────────────────────────────────
#  MeetStream Labs — environment configuration
#  Copy this file to .env and fill in the three required values.
# ──────────────────────────────────────────────────────────────

# 1. Your MeetStream API key
#    Dashboard → API Keys → Create Key
#    https://dashboard.meetstream.ai
MEETSTREAM_API_KEY=your_meetstream_api_key_here

# 2. Your ngrok authentication token  (free account is fine)
#    https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# 3. The meeting you want the bot to join
#    Supports Google Meet, Zoom, and Microsoft Teams URLs
MEETING_LINK=https://meet.google.com/xxx-xxxx-xxx

# ──────────────────────────────────────────────────────────────
#  Optional
# ──────────────────────────────────────────────────────────────

# Local port for the webhook + WebSocket server (default: 3000)
# PORT=3000

# Max simultaneous external apps allowed on /stream (default: 10)
# Protects against unbounded resource use if too many consumers connect.
# MAX_STREAM_CLIENTS=10

# ──────────────────────────────────────────────────────────────
#  External application bridge (bridge.js)
# ──────────────────────────────────────────────────────────────
# Choose which external app receives the live audio stream.
# Options out of the box: deepgram | assemblyai | console
# Add your own anytime — see src/providers/provider-interface.js
STT_PROVIDER=console

# Required only if STT_PROVIDER=deepgram
# Free signup, $200 credit, no card: https://console.deepgram.com/signup
# DEEPGRAM_API_KEY=your_deepgram_key_here

# Required only if STT_PROVIDER=assemblyai
# Free signup: https://www.assemblyai.com/dashboard/signup
# ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# Required only if STT_PROVIDER=openai-whisper
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_key_here


