# ─────────────────────────────────────────────
#  MeetStream Post-Call Transcription Bot
# ─────────────────────────────────────────────

# Your MeetStream API key (from the dashboard)
MEETSTREAM_API_KEY="your-meetstream-api-key"

# The meeting you want the bot to join
# Supports: Zoom, Google Meet, Microsoft Teams
MEETING_LINK=your-meeting-id

# Public URL MeetStream will POST webhook events to.
# When testing locally, use ngrok:
#   ngrok http 3000
# Then set this to your ngrok URL, e.g.:
#   WEBHOOK_URL=https://abc123.ngrok-free.app/webhook
WEBHOOK_URL=your-webhook-url

# Local port for the webhook server (default: 3000)
PORT=3000

# Optional: HMAC secret for webhook signature verification
# Set this in the MeetStream dashboard if you want to verify signatures.
# WEBHOOK_SECRET=your_webhook_secret
