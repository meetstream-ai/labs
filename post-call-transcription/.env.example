# ─────────────────────────────────────────────
#  MeetStream Post-Call Transcription Bot
# ─────────────────────────────────────────────

# Your MeetStream API key (from https://app.meetstream.ai)
MEETSTREAM_API_KEY=your_meetstream_api_key_here

# The meeting you want the bot to join
# Supports: Zoom, Google Meet, Microsoft Teams
MEETING_LINK=https://meet.google.com/xxx-xxxx-xxx

# Free ngrok auth token (from https://dashboard.ngrok.com/get-started/your-authtoken)
# ngrok is bundled — no separate install needed
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Local port for the webhook server (default: 3000)
PORT=3000

# Optional: HMAC secret for webhook signature verification
# WEBHOOK_SECRET=your_webhook_secret
